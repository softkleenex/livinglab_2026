# [Database]
# Managed Cloud PostgreSQL (Supabase, Neon, Render)
DATABASE_URL=postgresql://user:password@host:port/dbname

# [Google OAuth]
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REFRESH_TOKEN=your-google-oauth-refresh-token

# [Google Drive Data Lake]
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-root-folder-id
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# [Google Gemini AI]
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-pro

# [Security]
# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:4173,http://localhost:5173,https://your-production-domain.com

# [App Settings]
ENV=production
DEBUG=False
